{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/uk",
      "destination": "/gb",
      "permanent": true
    },
    {
      "source": "/privacy.html",
      "destination": "/privacy",
      "permanent": true
    },
    { "source": "/school-term-dates", "destination": "/school-term-dates/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://api.housemait.com/api/:path*" },
    { "source": "/school-term-dates/", "destination": "https://api.housemait.com/school-term-dates/" },
    { "source": "/school-term-dates/:path*", "destination": "https://api.housemait.com/school-term-dates/:path*" },
    { "source": "/(.*)", "destination": "/app.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
