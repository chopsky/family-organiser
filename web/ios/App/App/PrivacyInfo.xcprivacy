<?xml version="1.0" encoding="UTF-8"?>
<!--
  App privacy manifest (Apple requires this from 1 May 2024 for any
  app that accesses certain "required reason" APIs). At present we
  only need one declaration — Calendar access for the EventKit
  integration shipped in 1.4.0+ (HousemaitCalendarPlugin.swift). The
  reason code here matches Apple's published taxonomy for displaying
  the user's calendar events inline.

  If we add more required-reason APIs later (file timestamps, system
  boot time, etc.) they each need their own entry in the
  NSPrivacyAccessedAPITypes array. Apple's docs:
  https://developer.apple.com/documentation/bundleresources/privacy_manifest_files

  NSPrivacyTracking=false because Housemait does not track users
  across apps or websites for advertising/analytics. The empty
  domains array reinforces that.
-->
<plist version="1.0">
<dict>
    <key>NSPrivacyTracking</key>
    <false/>
    <key>NSPrivacyTrackingDomains</key>
    <array/>
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
