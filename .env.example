# ─── Supabase ─────────────────────────────────────────────────────────────────
# From: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ─── WhatsApp (via Twilio) ───────────────────────────────────────────────────
# From: https://console.twilio.com
# Leave unset to disable WhatsApp
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_NUMBER=+14155238886

# ─── AI Services ──────────────────────────────────────────────────────────────
# From: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# From: https://platform.openai.com (used for Whisper voice transcription)
OPENAI_API_KEY=your_openai_api_key_here

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ─── Cloudflare Turnstile (bot protection on register/login/forgot/contact) ──
# From: Cloudflare dashboard → Turnstile → Add Site
# Leave unset to disable bot protection (middleware fail-opens with a warning).
# TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxxxxxxxxx
# Web side also needs VITE_TURNSTILE_SITE_KEY in web/.env.production.

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Production only: your Vercel/Netlify frontend URL (no trailing slash)
# Leave unset in development — all origins allowed
# WEB_URL=https://your-app.vercel.app

# ─── Scheduling ───────────────────────────────────────────────────────────────
DAILY_REMINDER_HOUR=08:00
WEEKLY_DIGEST_DAY=0

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
