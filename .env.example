# ─── Supabase ─────────────────────────────────────────────────────────────────
# From: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ─── Telegram ─────────────────────────────────────────────────────────────────
# From: @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Production only: public URL of your deployed backend (no trailing slash)
# e.g. https://family-organiser.railway.app
# Leave unset in development — uses long-polling instead
# WEBHOOK_URL=https://your-app.railway.app

# ─── AI Services ──────────────────────────────────────────────────────────────
# From: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# From: https://platform.openai.com (used for Whisper voice transcription)
OPENAI_API_KEY=your_openai_api_key_here

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Production only: your Vercel/Netlify frontend URL (no trailing slash)
# Leave unset in development — all origins allowed
# WEB_URL=https://your-app.vercel.app

# ─── Scheduling ───────────────────────────────────────────────────────────────
DAILY_REMINDER_HOUR=08:00
WEEKLY_DIGEST_DAY=0

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
